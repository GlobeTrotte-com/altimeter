{
  "compilerOptions": {
    "declaration": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "types": ["node"]
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "bin/**/*",
    "dist/**/*"
  ]
}
