{
  "name": "@globetrotte/altimeter",
  "version": "0.0.5",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "altimeter": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && npm run esbuild",
    "esbuild": "esbuild --bundle --platform=node --packages=external ./cli.ts ./index.ts --outdir=dist --allow-overwrite",
    "lint": "eslint \"**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && ./bin/cli.js doc/config.json",
    "postinstall": "npx playwright install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GlobeTrotte-com/altimeter.git"
  },
  "keywords": ["altimeter", "preview", "screenshot", "link", "image"],
  "dependencies": {
    "playwright-core": "1.61.1"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "license": "MIT"
}
